# Mobile Tavern 云端后端环境变量示例
# 复制为 .env 并填充真实值。生产环境通过 Docker secrets 或 K8s ConfigMap 注入。

# ─── 数据库 ────────────────────────────────────────────────────
POSTGRES_DB=tavern
POSTGRES_USER=tavern
POSTGRES_PASSWORD=tavern_dev
DATABASE_URL=postgres://tavern:tavern_dev@localhost:5432/tavern

# ─── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6380

# ─── 服务端口 ──────────────────────────────────────────────────
PORT=8080
RUST_LOG=info,mobile_tavern_cloud=debug

# ─── JWT 签发（P1 账号体系）────────────────────────────────────
# 生产环境必须替换为强随机串（至少 32 字节）
# 生成命令：openssl rand -base64 48
JWT_SECRET=dev_secret_change_me_in_production_to_at_least_32_bytes
JWT_EXPIRES_HOURS=24
JWT_REFRESH_EXPIRES_DAYS=30

# ─── Google OAuth（P1 账号体系）───────────────────────────────
# 从 Google Cloud Console > APIs & Services > Credentials 获取
GOOGLE_CLIENT_ID=

# ─── SMTP 邮件（P1 邮箱验证）──────────────────────────────────
# 推荐 Resend（免费 3000 封/月）：https://resend.com
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@example.com

# ─── CORS 白名单（生产环境收紧）───────────────────────────────
# 移动端 App 的请求 Origin（Tauri WebView 的 tauri:// 协议或自定义 schema）
CORS_ALLOWED_ORIGINS=tauri://localhost,capacitor://localhost,http://localhost:3000