{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Tauri Dev (CodeLLDB)",
      "type": "lldb",
      "request": "launch",
      "cargo": {
        "args": [
          "build",
          "--manifest-path=./src-tauri/Cargo.toml"
        ]
      },
      "preLaunchTask": "ui:dev"
    },
    {
      "name": "Tauri Dev (MSVC Windows)",
      "type": "cppvsdbg",
      "request": "launch",
      "program": "${workspaceRoot}/src-tauri/target/debug/app.exe",
      "cwd": "${workspaceRoot}/src-tauri",
      "preLaunchTask": "ui:dev"
    }
  ]
}
