{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    {
      "identifier": "http:default",
      "allow": [
        { "url": "https://**" },
        { "url": "http://127.0.0.1" },
        { "url": "http://127.0.0.1:**" },
        { "url": "http://localhost" },
        { "url": "http://localhost:**" }
      ]
    }
  ]
}
