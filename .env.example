# ============================================================
# Mobile Tavern 环境变量示例
# ============================================================
# 复制本文件为 .env 并填入实际值。
# 注意：客户端 API Key 不在此配置，由用户在 App 内设置界面输入并
# 经 AES-GCM 加密后存储于 IndexedDB（参见 AGENTS.md 准则一.2）。
# 本文件仅用于本地开发服务端（server.ts）的可选配置。
# ============================================================

# NODE_ENV: 运行环境（development / production）
NODE_ENV=development

# 注意：更新检查签名验证机制已移除（客户端不再持有 HMAC 密钥），
# UPDATE_CHECK_SECRET 不再使用，保留此注释供历史参考。
