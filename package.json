{
  "name": "mobile-tavern",
  "private": true,
  "license": "Apache-2.0",
  "version": "1.6.2",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "start": "node server.ts",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "preview": "vite preview",
    "clean": "rm -rf dist server.js",
    "lint": "tsc --noEmit",
    "tauri": "tauri",
    "build:android": "node scripts/build-android.cjs",
    "dev:android": "node scripts/decode_icon.cjs && tauri android dev --host 127.0.0.1",
    "bump-version": "node scripts/bump-version.cjs",
    "test": "tsx tests/run_all_tests.ts",
    "test:zod": "node tests/test_zod_compatibility.cjs",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install chromium"
  },
  "dependencies": {
    "@aliyun-sls/web-sts-plugin": "^0.3.9",
    "@aliyun-sls/web-track-browser": "^0.3.9",
    "@base-ui/react": "^1.5.0",
    "@fontsource-variable/geist": "^5.2.9",
    "@google/genai": "^1.29.0",
    "@tailwindcss/vite": "^4.1.14",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-http": "^2.0.0",
    "@tauri-apps/plugin-log": "^2.8.0",
    "@types/jquery": "^4.0.1",
    "@vitejs/plugin-react": "^5.0.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "compare-versions": "^6.1.1",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "fflate": "^0.8.3",
    "jquery": "^4.0.0",
    "json5": "^2.2.3",
    "jsonrepair": "^3.14.0",
    "klona": "^2.0.6",
    "lodash": "^4.18.1",
    "lucide-react": "^0.546.0",
    "mathjs": "^15.2.0",
    "motion": "^12.23.24",
    "pinia": "^3.0.4",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "shadcn": "^4.8.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "vite": "^6.2.3",
    "vue": "^3.5.35"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@tauri-apps/cli": "^2.11.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/express": "^4.17.21",
    "@types/lodash": "^4.17.24",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.0",
    "fake-indexeddb": "^6.2.5",
    "happy-dom": "^15.11.7",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3",
    "vitest": "^2.1.8"
  }
}
